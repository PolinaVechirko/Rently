{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=rently.db"
  },
  "Jwt": {
    "Key": "change-this-local-development-secret",
    "Issuer": "RentlyApi",
    "Audience": "RentlyClient",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173"
    ]
  },
  "ImageUpload": {
    "MaxBytes": 5242880,
    "MaxWidth": 4096,
    "MaxHeight": 4096
  }
}
